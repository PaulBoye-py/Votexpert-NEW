{
  "name": "votexpert-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk --profile paul-arthurite",
    "deploy": "cdk deploy --all --profile paul-arthurite",
    "deploy:dev": "cdk deploy --all --context env=dev --require-approval never --profile paul-arthurite",
    "deploy:prod": "cdk deploy --all --context env=prod --profile paul-arthurite",
    "synth": "cdk synth --profile paul-arthurite",
    "diff": "cdk diff --profile paul-arthurite",
    "destroy": "cdk destroy --all --profile paul-arthurite"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@vendia/serverless-express": "^4.12.6",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "nodemailer": "^6.9.16",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "^2.170.0",
    "esbuild": "^0.24.2",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
