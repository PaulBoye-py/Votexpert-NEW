      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Sign Up",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "https://cognito-idp.us-east-1.amazonaws.com/",
              "protocol": "https",
              "host": ["cognito-idp", "us-east-1", "amazonaws", "com"],
              "path": ["/"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.SignUp" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ClientId\": \"{{clientId}}\",\n  \"Username\": \"{{email}}\",\n  \"Password\": \"{{password}}\",\n  \"UserAttributes\": [\n    { \"Name\": \"name\", \"Value\": \"Test Admin\" },\n    { \"Name\": \"custom:org_name\", \"Value\": \"{{orgName}}\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Sign up successful', function() {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "  if (pm.response.code === 400) {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.__type).to.include('UsernameExistsException');",
                  "    console.log('User already exists — skip to Sign In');",
                  "  } else {",
                  "    console.log('✅ Signed up. Check email for OTP code.');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Confirm OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "https://cognito-idp.us-east-1.amazonaws.com/",
              "protocol": "https",
              "host": ["cognito-idp", "us-east-1", "amazonaws", "com"],
              "path": ["/"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.ConfirmSignUp" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ClientId\": \"{{clientId}}\",\n  \"Username\": \"{{email}}\",\n  \"ConfirmationCode\": \"PASTE_OTP_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OTP confirmed', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  console.log('✅ Email confirmed. Run Sign In next.');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Sign In",
          "request": {
            "method": "POST",
            "url": {
              "raw": "https://cognito-idp.us-east-1.amazonaws.com/",
              "protocol": "https",
              "host": ["cognito-idp", "us-east-1", "amazonaws", "com"],
              "path": ["/"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.InitiateAuth" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ClientId\": \"{{clientId}}\",\n  \"AuthFlow\": \"USER_PASSWORD_AUTH\",\n  \"AuthParameters\": {\n    \"USERNAME\": \"{{email}}\",\n    \"PASSWORD\": \"{{password}}\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Sign in successful', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  const token = body.AuthenticationResult.IdToken;",
                  "  pm.collectionVariables.set('token', token);",
                  "  console.log('✅ Token saved to collection variable.');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
