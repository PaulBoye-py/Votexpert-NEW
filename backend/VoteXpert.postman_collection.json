    },
    {
      "name": "📊 Results",
      "item": [
        {
          "name": "Get Results",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/results/{{electionId}}", "host": ["{{baseUrl}}"], "path": ["results", "{{electionId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Got results', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  body.data.positions.forEach(p => {",
                  "    console.log('\\nPosition:', p.position.title);",
                  "    console.log('Total votes:', p.total_votes);",
                  "    p.candidates.forEach(c => {",
                  "      console.log(' -', c.name, ':', c.vote_count, 'votes (' + c.percentage + '%)');",
                  "    });",
                  "    if (p.winner) console.log('Winner:', p.winner.name);",
