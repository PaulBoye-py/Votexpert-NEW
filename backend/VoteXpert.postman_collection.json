          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Session created', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('sessionToken', body.data.session_token);",
                  "  console.log('✅ sessionToken:', body.data.session_token);",
                  "  console.log('Active position:', JSON.stringify(body.data.active_position, null, 2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Cast Vote (for Alice)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/vote/cast", "host": ["{{baseUrl}}"], "path": ["vote", "cast"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"election_id\": \"{{electionId}}\",\n  \"position_id\": \"{{positionId}}\",\n  \"candidate_id\": \"{{candidateId}}\",\n  \"session_token\": \"{{sessionToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Vote cast', function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "  const body = pm.response.json();",
                  "  console.log('✅ Vote count for Alice:', body.data.vote_count);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Try Voting Again (should fail)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/vote/cast", "host": ["{{baseUrl}}"], "path": ["vote", "cast"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"election_id\": \"{{electionId}}\",\n  \"position_id\": \"{{positionId}}\",\n  \"candidate_id\": \"{{candidateId2}}\",\n  \"session_token\": \"{{sessionToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Duplicate vote rejected (409)', function() {",
                  "  pm.expect(pm.response.code).to.equal(409);",
                  "  console.log('✅ Correctly rejected duplicate vote');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔒 Voting — Closed Election",
