                  "  const body = pm.response.json();",
                  "  console.log('Voter:', body.data.voter_id);",
                  "  console.log('Active position:', JSON.stringify(body.data.active_position, null, 2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Cast Vote (Closed)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/vote/cast", "host": ["{{baseUrl}}"], "path": ["vote", "cast"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"election_id\": \"{{closedElectionId}}\",\n  \"position_id\": \"POSITION_ID_HERE\",\n  \"candidate_id\": \"CANDIDATE_ID_HERE\",\n  \"invite_token\": \"{{inviteToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
