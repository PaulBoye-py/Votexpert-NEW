              "host": ["{{baseUrl}}"],
              "path": ["vote", "verify-token"],
              "query": [{ "key": "token", "value": "{{inviteToken}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token verified', function() {",
